# Render (like most hosts) sets NODE_ENV=production, and npm then SKIPS
# devDependencies entirely.
#
# `next build` needs them: typescript, tailwindcss, postcss and the @types/*
# packages are all devDependencies. Without this line the production build fails
# on the host even though it works perfectly on your machine.
#
# This affects INSTALL only — the built output does not ship them.
include=dev
