# Port the Express + Socket.io server listens on.
PORT=5000

# MongoDB connection string (Atlas or local).
# The server is the only service that touches the database.
MONGODB_URI=mongodb://127.0.0.1:27017/viboz-chat

# Secret used to sign and verify auth JWTs. Minimum 16 characters.
# The server is the sole issuer and verifier — nothing to keep in sync.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Origin allowed to call this API and open a Socket.io connection.
# Comma-separate for multiple origins.
CLIENT_ORIGIN=http://localhost:3000
