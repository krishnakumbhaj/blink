# Render (like most hosts) sets NODE_ENV=production, and npm then SKIPS
# devDependencies entirely.
#
# But the build needs them: `typescript` and every `@types/*` package live in
# devDependencies. Without this line the deploy fails with a baffling
#
#   error TS2688: Cannot find type definition file for 'node'
#
# rather than an honest "tsc: not found" — because @types/node gets pulled in
# transitively by a runtime package while TypeScript itself does not.
#
# This affects INSTALL only. Nothing extra ships to the running server: the build
# compiles TypeScript away, and `npm start` runs plain JavaScript from dist/.
include=dev
